# ===========================================
# TokenLive 一键部署配置
# ===========================================

# ------------------------------
# 基础配置
# ------------------------------
# 域名配置（可选，启用后自动获取 HTTPS 证书）
DOMAIN=your-domain.com

# 端口配置
HTTP_PORT=80
HTTPS_PORT=443

# Admin Console 管理员密码
ADMIN_PASSWORD=admin

# Admin 数据库类型 (默认 sqlite3, 可选 mysql/postgres)
DB_TYPE=sqlite3

# Gateway 与 Admin 之间的同步 Token（生产环境必须修改！）
GATEWAY_SYNC_TOKEN=default_tokenlive_sync_secret_token_2026

# ------------------------------
# Gateway 配置
# ------------------------------
# Gateway 内部端口（不需要对外暴露）
GATEWAY_PORT=8000

# Gateway API Key（可选）
GATEWAY_API_KEY=your-api-key-here

# ------------------------------
# Redis 配置（可选）
# ------------------------------
# 启用 Redis 后可以支持：
# - Gateway 多实例部署
# - Admin 配置热同步
# - 持久化限流、熔断状态
#
# 启用方式：docker compose --profile with-redis up -d
#
# REDIS_ADDR=redis:6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ------------------------------
# Prometheus 配置（可选）
# ------------------------------
# 启用方式：docker compose --profile with-monitoring up -d
#
# PROMETHEUS_SERVER_URL=http://prometheus:9090
# PROMETHEUS_SERVER_USERNAME=
# PROMETHEUS_SERVER_PASSWORD=

# ------------------------------
# 高级配置（通常不需要修改）
# ------------------------------
# Admin Console 内部地址（不需要对外暴露）
ADMIN_URL=http://admin:8040
ADMIN_PORT=8040

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 数据库配置（SQLite 通常不需要修改）
# DB_DRIVER=sqlite
# DB_DSN=/data/tokenlive.db

# ------------------------------
# 云服务 API Key（在 Admin 后台配置更安全）
# ------------------------------
# 这些可以在 Admin 后台配置，不需要在这里填
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AZURE_API_KEY=
